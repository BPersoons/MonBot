# ============================================
# ADK MIGRATION ENVIRONMENT CONFIGURATION
# ============================================

# --- Existing Configuration (preserved) ---

# Exchange API Keys
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key

KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_SECRET_KEY=your_kraken_secret_key

# Other Settings
LOG_LEVEL=INFO

# --- ADK Configuration ---

# ADK State Backend (redis recommended for production)
ADK_STATE_BACKEND=redis

# Redis Configuration (used for StateStore AND Circuit Breaker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Supabase Configuration ---

# Supabase Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase API Key (anon/public key for client)
SUPABASE_KEY=your-supabase-anon-key

# Supabase Database Password (for direct PostgreSQL access if needed)
SUPABASE_DB_PASSWORD=your-db-password

# --- Optional: Local PostgreSQL (for docker-compose development) ---

POSTGRES_USER=trader
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=agent_trader
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Google AI Configuration ---

# Google API Key for Gemini models (if not using service account)
GOOGLE_API_KEY=your-google-api-key

# Google Cloud Project ID (if using Vertex AI)
GOOGLE_CLOUD_PROJECT=your-project-id
